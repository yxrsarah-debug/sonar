# =============================================================================
# Sonar — environment configuration
# Copy to `.env.local` and fill in. Every adapter has a labeled dev fallback,
# so the app runs WITHOUT any of these — but real keys switch on the real path.
# =============================================================================

# ---- Nimble (SENSE: real news + social via Web Search Agents) ----------------
# Get your key: https://online.nimbleway.com/account-settings/api-keys
NIMBLE_API_KEY=
NIMBLE_BASE_URL=https://sdk.nimbleway.com/v1

# ---- ClickHouse (THINK: store events + run divergence analytics) ------------
# https://clickhouse.com  (ClickHouse Cloud gives you URL + user + password)
# If CLICKHOUSE_URL is empty, Sonar uses an in-memory dev store instead.
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=sonar

# ---- x402 (TRANSACT: agents pay per read — real USDC on Base Sepolia) --------
# https://docs.cdp.coinbase.com/x402
# Seller wallet that RECEIVES payments (any EVM address you control):
X402_PAY_TO=
# Buyer agent wallet PRIVATE KEY (0x-prefixed), funded with Base Sepolia test
# USDC from https://faucet.circle.com . TESTNET ONLY — never use real funds.
EVM_PRIVATE_KEY=
X402_NETWORK=base-sepolia
X402_ASSET=USDC
X402_PRICE_USDC=0.05
# PayAI facilitator settles testnet payments for free (no CDP key needed):
X402_FACILITATOR_URL=https://facilitator.payai.network

# ---- App --------------------------------------------------------------------
# Comma-separated tickers the radar watches.
SONAR_WATCHLIST=NVDA,TSLA,AAPL,META,AMD

# Note: prices (Stooq/Yahoo) and Polymarket (Gamma/CLOB) are keyless — no env needed.
